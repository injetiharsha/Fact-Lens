# API Keys
GROQ_API_KEY=your_groq_key
GROQ_API_KEYS=
TAVILY_API_KEY=your_tavily_key
TAVILY_API_KEYS=your_tavily_key_1,your_tavily_key_2
SERPAPI_KEY=your_serpapi_key
OPENAI_API_KEY=your_openai_key
OPENROUTER_API_KEY=your_openrouter_key
SARVAM_API_SUBSCRIPTION_KEY=your_sarvam_subscription_key
SARVAM_API_KEY=
SARVAM_REASONING_EFFORT=medium
NASA_API_TIMEOUT_SECONDS=20
OPENFDA_API_TIMEOUT_SECONDS=20

# Model Paths
CHECKABILITY_EN_PATH=./checkpoints/checkability/en
CHECKABILITY_MULTI_PATH=./checkpoints/checkability/multi
CONTEXT_EN_PATH=./checkpoints/context/en
CONTEXT_MULTI_PATH=./checkpoints/context/multi
RELEVANCE_EN_PATH=./checkpoints/relevance/en
RELEVANCE_MULTI_PATH=./checkpoints/relevance/multi
STANCE_EN_PATH=./checkpoints/stance/en
STANCE_MULTI_PATH=./checkpoints/stance/multi

# Settings
LOG_LEVEL=INFO
PIPELINE_LOCK_EN=0
EN_LOCK_STAGE_ORDER=structured_api,scraping,web_search
EN_LOCK_STAGE_MIN_RESULTS=6
EN_LOCK_STAGE_PARALLEL_WITHIN=1
EN_LOCK_ENABLE_SCRAPER_ENRICHMENT=1
EN_LOCK_SCRAPER_ENRICH_MAX_RESULTS=10
EN_LOCK_WEB_MAX_QUERIES_EN=3
EN_LOCK_WEB_MIN_PROVIDERS_BEFORE_STOP=3
EN_LOCK_WEB_PROVIDER_FAIL_FAST=0
PIPELINE_LIVE_PROGRESS=0
DEVICE=cuda
BATCH_SIZE=32
PIPELINE_MAX_EVIDENCE=5
PIPELINE_MAX_EVIDENCE_MULTI=12
OCR_IMAGE_LANGS=eng+hin+tam+tel+kan+mal
OCR_TESSERACT_MIN_CONF=0.7
OCR_ENABLE_EASYOCR=0
PDF_MAX_PAGES=5
PDF_MAX_EXTRACTED_CHARS=30000
PDF_FORCE_SINGLE_CLAIM_WHEN_CLAIM_PROVIDED=1
PDF_ENABLE_OCR_FALLBACK=1

# Global request guard (all endpoints, includes concurrent)
GLOBAL_REQUESTS_PER_MINUTE=30
MAX_CONCURRENT_REQUESTS=4
BENCHMARK_CLAIM_TIMEOUT_SECONDS=180

# Checkpoint toggles
ENABLE_CHECKABILITY_EN=1
ENABLE_CHECKABILITY_MULTI=1
ENABLE_CONTEXT_EN=1
ENABLE_CONTEXT_MULTI=1
ENABLE_RELEVANCE_EN=1
ENABLE_RELEVANCE_MULTI=1
ENABLE_TWO_STAGE_RELEVANCE=1
RELEVANCE_BI_ENCODER_MODEL=intfloat/multilingual-e5-small
RELEVANCE_SHORTLIST_K=20
RELEVANCE_TOP_K=0
# Keep-threshold after relevance scoring (single source of truth).
RELEVANCE_KEEP_THRESHOLD=0.30
# Deprecated alias (kept for backward compatibility).
RELEVANCE_DROP_THRESHOLD=0.30
ENABLE_STANCE_EN=1
ENABLE_STANCE_MULTI=1

# LLM verifier
ENABLE_LLM_VERIFIER=1
LLM_VERIFIER_PROVIDER=openai
LLM_VERIFIER_MODEL=gpt-4o-mini
LLM_VERIFIER_BASE_URL=
LLM_VERIFIER_PROVIDER_EN=groq
LLM_VERIFIER_MODEL_EN=openai/gpt-oss-120b
LLM_VERIFIER_PROVIDER_MULTI=sarvam
LLM_VERIFIER_MODEL_MULTI=sarvam-30b
LLM_VERIFIER_BASE_URL_EN=https://api.groq.com/openai/v1
LLM_VERIFIER_BASE_URL_MULTI=https://api.sarvam.ai/v1
LLM_VERIFIER_NEUTRAL_ONLY=1
LLM_VERIFIER_REQUESTS_PER_MINUTE=30
LLM_VERIFIER_GLOBAL_RATE_LIMIT=1
LLM_VERIFIER_GLOBAL_RATE_DB=F:/RFCS/.llm_verifier_rate_limit.sqlite
# Shared limiter for all chat-completions call-sites (verifier + helper fallbacks)
LLM_SHARED_REQUESTS_PER_MINUTE=25
LLM_SHARED_MAX_CONCURRENT=
LLM_SHARED_GLOBAL_RATE_LIMIT=
LLM_SHARED_RATE_DB=
LLM_SHARED_429_COOLDOWN_SECONDS=3
SARVAM_REQUESTS_PER_MINUTE=40
SARVAM_API_BASE_URL=https://api.sarvam.ai/v1

# Translation LLM (separate from multi verifier)
TRANSLATION_LLM_PROVIDER=groq
TRANSLATION_LLM_MODEL=openai/gpt-oss-120b
TRANSLATION_LLM_BASE_URL=
SARVAM_TRANSLATE_ENABLE=1
SARVAM_TRANSLATE_API_URL=https://api.sarvam.ai/translate
SARVAM_TRANSLATE_MODEL=mayura:v1
SARVAM_TRANSLATE_TARGET_LANGUAGE=en-IN
SARVAM_TRANSLATE_MODE=modern-colloquial
SARVAM_TRANSLATE_SPEAKER_GENDER=Male
SARVAM_TRANSLATE_ENABLE_PREPROCESSING=0
SARVAM_TRANSLATE_NUMERALS_FORMAT=native
SARVAM_TRANSLATE_TIMEOUT_SECONDS=20

# Web search minimal controls (fast defaults are in code)
# Provider order tokens: ddg,tavily,serpapi
# Tier-1 default is free search first.
WEB_SEARCH_PROVIDER_ORDER=ddg
# Paid escalation order is used only when candidate quality gate fails.
WEB_SEARCH_ESCALATION_PROVIDER_ORDER=serpapi,tavily
WEB_SEARCH_ENABLE_DDG=1
WEB_SEARCH_ENABLE_SERPAPI=1
WEB_SEARCH_ENABLE_TAVILY=1
WEB_SEARCH_PAID_ESCALATION_ENABLE=1
WEB_SEARCH_FORCE_PROVIDER_ORDER=0
WEB_SEARCH_MIN_PROVIDERS_BEFORE_STOP=1
WEB_SEARCH_ESCALATION_MIN_UNIQUE_DOMAINS=3
WEB_SEARCH_ESCALATION_MIN_TRUSTED_HITS=1
WEB_SEARCH_ESCALATION_MIN_AVG_PRESCORE=0.10
WEB_SEARCH_MAX_QUERIES_EN=3
WEB_SEARCH_MAX_QUERIES_MULTI=2
WEB_SEARCH_MAX_TOTAL_RESULTS_MULTI=12
MULTI_ENABLE_EN_QUERY_TRANSLATION=1
MULTI_QUERY_TRANSLATION_MODEL=ai4bharat/indictrans2-indic-en-dist-200M
MULTI_QUERY_TRANSLATION_CPU=0
MULTI_QUERY_TRANSLATION_MAX_LENGTH=256
MULTI_QUERY_TRANSLATION_LOCAL_ENABLE=0
MULTI_QUERY_TRANSLATION_PREFER_LLM=1
MULTI_QUERY_TRANSLATION_WEB_ENABLE=0
MULTI_QUERY_TRANSLATION_LLM_COOLDOWN_SEC=30
MULTI_QUERY_TRANSLATION_LLM_RETRIES=2
MULTI_QUERY_TRANSLATION_LLM_BACKOFF_SEC=0.6
MULTI_NEUTRAL_TAVILY_BOOST_ENABLE=0
MULTI_NEUTRAL_TAVILY_BOOST_THRESHOLD=0.6
MULTI_NEUTRAL_TAVILY_BOOST_MAX_QUERIES=2
MULTI_NEUTRAL_TAVILY_BOOST_MAX_RESULTS=5
EVIDENCE_PARALLEL_SOURCES=1
EVIDENCE_PARALLEL_SOURCE_WORKERS=4
EVIDENCE_ENABLE_SCRAPER_ENRICHMENT=1
EVIDENCE_MMR_ENABLED=1
EVIDENCE_MMR_IMAGE_ONLY=1
EVIDENCE_MMR_LAMBDA=0.75
EVIDENCE_MMR_CANDIDATES_MULT=3
SCRAPER_PARALLEL_URLS=1
SCRAPER_PARALLEL_WORKERS=4
SCRAPER_BAD_DOMAINS=dailymotion.com,facebook.com,instagram.com,x.com,twitter.com,tiktok.com,snapchat.com,reddit.com,pinterest.com,youtube.com,youtu.be,threads.net,discord.com,telegram.org,mastodon.social,weibo.com,tumblr.com
WEB_SEARCH_BAD_DOMAINS=dailymotion.com,facebook.com,instagram.com,x.com,twitter.com,tiktok.com,snapchat.com,reddit.com,pinterest.com,youtube.com,youtu.be,threads.net,discord.com,telegram.org,mastodon.social,weibo.com,tumblr.com
SCRAPER_BLOCK_EXPLICIT=1
WEB_SEARCH_BLOCK_EXPLICIT=1
SCRAPER_BLOCKED_URL_TOKENS=/questions/,/question/,/questiosn/,/mcq,mcq/,quiz,quizzes,podcast,audio,/categories/44/
WEB_SEARCH_BLOCKED_URL_TOKENS=/questions/,/question/,/questiosn/,/qna/,/qa/,/mcq,mcq/,quiz,quizzes,podcast,audio,/shorts/,/reel/,/reels/,/watch?,/video/,/categories/44/
ENABLE_DOCUMENT_CHECKABILITY_FILTER=1

# Retrieval quality controls
RELEVANCE_MIN_KEEP_MULTI=5
EVIDENCE_MAX_PER_DOMAIN=2
EVIDENCE_DOMAIN_MAX_PER_HOST=2
NEUTRAL_RECOVERY_ENABLE=1
NEUTRAL_RECOVERY_MAX_QUERIES=2
NEUTRAL_RECOVERY_MAX_RESULTS=6
NEUTRAL_RECOVERY_KEEP_THRESHOLD=3

SCRAPER_PARALLEL_METHODS=1
SCRAPER_ENABLE_PLAYWRIGHT_FALLBACK=1
SCRAPER_PLAYWRIGHT_SHORT_TEXT_THRESHOLD=450
SCRAPER_PLAYWRIGHT_HEAVY_MODE=1
SCRAPER_PLAYWRIGHT_HEAVY_WAIT_MS=2000

# Sarvam final reranker on kept MULTI evidence
ENABLE_SARVAM_FINAL_RERANK=0
SARVAM_RERANK_MULTI_ONLY=1
SARVAM_RERANK_TOP_K=10
SARVAM_RERANK_MODEL=sarvam-30b
SARVAM_RERANK_MAX_TOKENS=1200
SARVAM_RERANK_RELEVANCE_BLEND=0.7
SARVAM_RERANK_MIN_STANCE_CONF=0.45
SARVAM_RERANK_USE_STANCE_OVERRIDE=0
SARVAM_RERANK_OVERRIDE_MIN_CONF=0.8

# Structured API reliability controls
STRUCTURED_API_PING=1
STRUCTURED_API_STRICT_HEALTH=1
# Optional explicit allowlist, comma separated (example):
# STRUCTURED_API_ALLOWLIST=wikipedia,worldbank,wikidata,pib,openfda

