# API Keys
GROQ_API_KEY=your_groq_key
TAVILY_API_KEY=your_tavily_key
TAVILY_API_KEYS=your_tavily_key_1,your_tavily_key_2
SERPAPI_KEY=your_serpapi_key
OPENAI_API_KEY=your_openai_key
OPENROUTER_API_KEY=your_openrouter_key
NASA_API_TIMEOUT_SECONDS=20
OPENFDA_API_TIMEOUT_SECONDS=20

# Model Paths
CHECKABILITY_EN_PATH=./checkpoints/checkability/en
CHECKABILITY_MULTI_PATH=./checkpoints/checkability/multi
CONTEXT_EN_PATH=./checkpoints/context/en
CONTEXT_MULTI_PATH=./checkpoints/context/multi
RELEVANCE_EN_PATH=./checkpoints/relevance/en
RELEVANCE_MULTI_PATH=./checkpoints/relevance/multi
STANCE_EN_PATH=./checkpoints/stance/en
STANCE_MULTI_PATH=./checkpoints/stance/multi

# Settings
LOG_LEVEL=INFO
PIPELINE_LIVE_PROGRESS=0
DEVICE=cuda
BATCH_SIZE=32
PIPELINE_MAX_EVIDENCE=5
OCR_IMAGE_LANGS=eng+hin+tam+tel+kan+mal
OCR_TESSERACT_MIN_CONF=0.7
OCR_ENABLE_EASYOCR=0

# Global request guard (all endpoints, includes concurrent)
GLOBAL_REQUESTS_PER_MINUTE=30
MAX_CONCURRENT_REQUESTS=4
BENCHMARK_CLAIM_TIMEOUT_SECONDS=180

# Checkpoint toggles
ENABLE_CHECKABILITY_EN=1
ENABLE_CHECKABILITY_MULTI=1
ENABLE_CONTEXT_EN=1
ENABLE_CONTEXT_MULTI=1
ENABLE_RELEVANCE_EN=1
ENABLE_RELEVANCE_MULTI=1
ENABLE_TWO_STAGE_RELEVANCE=1
RELEVANCE_BI_ENCODER_MODEL=intfloat/multilingual-e5-small
RELEVANCE_SHORTLIST_K=20
RELEVANCE_TOP_K=0
RELEVANCE_DROP_THRESHOLD=0.07
ENABLE_STANCE_EN=1
ENABLE_STANCE_MULTI=1

# LLM verifier
ENABLE_LLM_VERIFIER=1
LLM_VERIFIER_PROVIDER=openai
LLM_VERIFIER_MODEL=gpt-4o-mini
LLM_VERIFIER_BASE_URL=
LLM_VERIFIER_NEUTRAL_ONLY=1
LLM_VERIFIER_REQUESTS_PER_MINUTE=30
LLM_VERIFIER_GLOBAL_RATE_LIMIT=1
LLM_VERIFIER_GLOBAL_RATE_DB=F:/RFCS/.llm_verifier_rate_limit.sqlite

# Web search minimal controls (fast defaults are in code)
# Provider order tokens: ddg,tavily,serpapi
WEB_SEARCH_PROVIDER_ORDER=ddg,tavily,serpapi
MULTI_ENABLE_EN_QUERY_TRANSLATION=1
MULTI_QUERY_TRANSLATION_MODEL=ai4bharat/indictrans2-indic-en-dist-200M
MULTI_QUERY_TRANSLATION_CPU=0
MULTI_QUERY_TRANSLATION_MAX_LENGTH=256
MULTI_NEUTRAL_TAVILY_BOOST_ENABLE=1
MULTI_NEUTRAL_TAVILY_BOOST_THRESHOLD=0.6
MULTI_NEUTRAL_TAVILY_BOOST_MAX_QUERIES=2
MULTI_NEUTRAL_TAVILY_BOOST_MAX_RESULTS=5
EVIDENCE_PARALLEL_SOURCES=1
EVIDENCE_PARALLEL_SOURCE_WORKERS=4
EVIDENCE_ENABLE_SCRAPER_ENRICHMENT=1
SCRAPER_PARALLEL_URLS=1
SCRAPER_PARALLEL_WORKERS=4
SCRAPER_BAD_DOMAINS=dailymotion.com,facebook.com,instagram.com,x.com,twitter.com,tiktok.com,snapchat.com,reddit.com,pinterest.com,youtube.com,youtu.be,threads.net,discord.com,telegram.org,mastodon.social,weibo.com,tumblr.com
