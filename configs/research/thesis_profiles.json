{
  "base_thesis_v1": {
    "description": "Exact benchmark runtime parity profile with only 3 overrides: Tavily OFF, SerpAPI OFF, LLM verifier OFF.",
    "env": {
      "ENABLE_LLM_VERIFIER": "0",
      "WEB_SEARCH_ENABLE_SERPAPI": "0",
      "WEB_SEARCH_ENABLE_TAVILY": "0",
      "SCORING_MODE": "heuristic"
    }
  },
  "secondary_api_search_v1": {
    "description": "Secondary improvement: enable paid/providers + recovery + verifier for stronger live retrieval.",
    "env": {
      "PIPELINE_LOCK_EN": "0",
      "ENABLE_LLM_VERIFIER": "1",
      "WEB_SEARCH_ENABLE_DDG": "1",
      "WEB_SEARCH_ENABLE_SERPAPI": "1",
      "WEB_SEARCH_ENABLE_TAVILY": "1",
      "MULTI_NEUTRAL_TAVILY_BOOST_ENABLE": "1",
      "IMAGE_ENABLE_TAVILY_BOOST": "1",
      "NEUTRAL_RECOVERY_ENABLE": "1",
      "NEUTRAL_QUALITY_GUARD_ENABLE": "1",
      "IMAGE_MULTI_EN_FALLBACK_ENABLE": "1",
      "ENABLE_POLARITY_CONFLICT_ADJUST": "1",
      "MULTI_PHASE1_GUARD_ENABLE": "1",
      "MULTI_PHASE3_TIERS_ENABLE": "1",
      "MULTI_PHASE4_LANE_WEIGHT_ENABLE": "1",
      "MULTI_PHASE5_GRAY_ZONE_ENABLE": "1",
      "MULTI_PHASE7_DECISIVE_VERDICT_ENABLE": "1",
      "MULTI_ENABLE_EN_QUERY_TRANSLATION": "1",
      "EVIDENCE_ENABLE_TRANSLATED_QUERY_SEARCH": "1",
      "MULTI_QUERY_TRANSLATION_LOCAL_ENABLE": "0",
      "MULTI_QUERY_TRANSLATION_WEB_ENABLE": "1",
      "MULTI_QUERY_TRANSLATION_PREFER_LLM": "1",
      "SCORING_MODE": "heuristic"
    }
  },
  "research_score_v1": {
    "description": "Strict scoring ablation: identical to base_thesis_v1 except scoring mode/weights.",
    "env": {
      "ENABLE_LLM_VERIFIER": "0",
      "WEB_SEARCH_ENABLE_SERPAPI": "0",
      "WEB_SEARCH_ENABLE_TAVILY": "0",
      "SCORING_MODE": "research",
      "SCORING_RESEARCH_ALPHA": "0.50",
      "SCORING_RESEARCH_BETA": "0.30",
      "SCORING_RESEARCH_GAMMA": "0.20"
    }
  },
  "en_benchmark_parity_v1": {
    "description": "EN benchmark-parity profile for Eval_150: benchmark-like providers/verifier/retrieval caps for stronger EN decisions.",
    "env": {
      "PIPELINE_LOCK_EN": "1",
      "ENABLE_LLM_VERIFIER": "1",
      "LLM_VERIFIER_PROVIDER_EN": "groq",
      "LLM_VERIFIER_MODEL_EN": "openai/gpt-oss-120b",
      "EVIDENCE_SOURCE_MODE": "staged_fallback",
      "EVIDENCE_STAGE_ORDER": "structured_api,scraping,web_search",
      "EVIDENCE_STAGE_MIN_RESULTS": "6",
      "EVIDENCE_STAGE_PARALLEL_WITHIN": "1",
      "PIPELINE_MAX_EVIDENCE": "10",
      "PIPELINE_MAX_EVIDENCE_MULTI": "10",
      "STRUCTURED_API_ALLOWLIST": "wikipedia,openfda,nasa,arxiv,worldbank,wikidata,pib",
      "STRUCTURED_API_PING": "1",
      "WEB_SEARCH_PROVIDER_ORDER": "ddg,tavily,serpapi",
      "WEB_SEARCH_MIN_PROVIDERS_BEFORE_STOP": "3",
      "WEB_SEARCH_MIN_RESULTS_BEFORE_FALLBACK": "999",
      "WEB_SEARCH_MAX_QUERIES": "3",
      "WEB_SEARCH_MAX_QUERIES_MULTI": "2",
      "WEB_SEARCH_MAX_TOTAL_RESULTS_EN": "30",
      "WEB_SEARCH_MAX_TOTAL_RESULTS_MULTI": "30",
      "WEB_SEARCH_PROVIDER_FAIL_FAST": "0",
      "WEB_SEARCH_ENABLE_DDG": "1",
      "WEB_SEARCH_ENABLE_SERPAPI": "1",
      "WEB_SEARCH_ENABLE_TAVILY": "1",
      "EVIDENCE_ENABLE_SCRAPER_ENRICHMENT": "1",
      "EVIDENCE_SCRAPER_ENRICH_MAX_RESULTS": "10",
      "EVIDENCE_DOMAIN_DIVERSITY_ENABLED": "1",
      "EVIDENCE_DOMAIN_MAX_PER_HOST": "2",
      "EVIDENCE_MMR_ENABLED": "1",
      "EVIDENCE_MMR_LAMBDA": "0.75",
      "EVIDENCE_MMR_CANDIDATES_MULT": "3",
      "SCRAPER_ENABLE_PLAYWRIGHT_FALLBACK": "1",
      "SCRAPER_PLAYWRIGHT_HEAVY_MODE": "1",
      "SCRAPER_URL_CANDIDATE_MULT": "2",
      "RELEVANCE_TOP_K": "10",
      "RELEVANCE_MIN_KEEP": "3",
      "RELEVANCE_MIN_KEEP_MULTI": "5",
      "MULTI_NEUTRAL_TAVILY_BOOST_ENABLE": "0",
      "IMAGE_ENABLE_TAVILY_BOOST": "0",
      "NEUTRAL_RECOVERY_ENABLE": "1",
      "NEUTRAL_QUALITY_GUARD_ENABLE": "1",
      "IMAGE_MULTI_EN_FALLBACK_ENABLE": "0",
      "ENABLE_POLARITY_CONFLICT_ADJUST": "1",
      "MULTI_PHASE1_GUARD_ENABLE": "1",
      "MULTI_PHASE2_MODE": "scored",
      "MULTI_PHASE2_CANDIDATE_CAP": "10",
      "MULTI_PHASE3_TIERS_ENABLE": "1",
      "MULTI_PHASE4_LANE_WEIGHT_ENABLE": "1",
      "MULTI_PHASE5_GRAY_ZONE_ENABLE": "1",
      "MULTI_PHASE7_DECISIVE_VERDICT_ENABLE": "1",
      "MULTI_ENABLE_EN_QUERY_TRANSLATION": "1",
      "EVIDENCE_ENABLE_TRANSLATED_QUERY_SEARCH": "1",
      "MULTI_QUERY_TRANSLATION_LOCAL_ENABLE": "0",
      "MULTI_QUERY_TRANSLATION_WEB_ENABLE": "0",
      "MULTI_QUERY_TRANSLATION_PREFER_LLM": "1",
      "SCORING_MODE": "heuristic"
    }
  },
  "en_web_only_ddg_v1": {
    "description": "EN-only ablation: web_search stage only, DDG enabled, Tavily/SerpAPI disabled, no LLM verifier.",
    "env": {
      "PIPELINE_LOCK_EN": "1",
      "ENABLE_LLM_VERIFIER": "0",
      "EVIDENCE_SOURCE_MODE": "staged_fallback",
      "EVIDENCE_STAGE_ORDER": "web_search",
      "EVIDENCE_STAGE_MIN_RESULTS": "999",
      "WEB_SEARCH_PROVIDER_ORDER": "ddg,tavily,serpapi",
      "WEB_SEARCH_ENABLE_DDG": "1",
      "WEB_SEARCH_ENABLE_TAVILY": "0",
      "WEB_SEARCH_ENABLE_SERPAPI": "0",
      "WEB_SEARCH_MIN_RESULTS_BEFORE_FALLBACK": "999",
      "WEB_SEARCH_MIN_PROVIDERS_BEFORE_STOP": "1",
      "EVIDENCE_ENABLE_SCRAPER_ENRICHMENT": "0",
      "NEUTRAL_RECOVERY_ENABLE": "0",
      "NEUTRAL_QUALITY_GUARD_ENABLE": "0",
      "SCORING_MODE": "heuristic"
    }
  }
}
